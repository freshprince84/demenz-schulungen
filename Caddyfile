# Bis echte Domain feststeht: HTTP auf Port 80 (kein TLS-Zwang für IP)
# Für Produktion mit Domain: Block unten durch TLS-Block ersetzen (siehe DEPLOYMENT.md)

:80 {
  encode gzip zstd

  header {
    X-Content-Type-Options "nosniff"
    X-Frame-Options "DENY"
    Referrer-Policy "strict-origin-when-cross-origin"
  }

  reverse_proxy app:3000
}

