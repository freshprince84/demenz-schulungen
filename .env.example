# Umgebungsvariablen — Beispiel
# Kopieren nach .env.local (lokal) bzw. Server-.env (Prod)
# NIEMALS committen mit echten Secrets

# Datenbank
DATABASE_URL=postgresql://demenz:demenz@localhost:5432/demenz_schulungen

# MiniMax (nur serverseitig verwenden)
MINIMAX_API_KEY=
MINIMAX_API_HOST=https://api.minimax.io

# Next.js / Auth (Phase 2)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# App
NODE_ENV=development
APP_URL=http://localhost:3000

# Optional: Log-Level
LOG_LEVEL=info
