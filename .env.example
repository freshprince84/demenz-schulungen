# Umgebungsvariablen — Beispiel
# Kopieren nach .env.local (lokal) bzw. .env (Prod auf demenz-prod)
# NIEMALS committen mit echten Secrets

# Datenbank (lokal: docker-compose.dev.yml)
DATABASE_URL=postgresql://demenz:demenz@localhost:5432/demenz_schulungen

# Prod Docker Compose (docker-compose.prod.yml)
POSTGRES_USER=demenz
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=demenz_schulungen

# Domain / TLS (Caddy)
DOMAIN=localhost
APP_URL=http://localhost:3000

# MiniMax (nur serverseitig verwenden)
MINIMAX_API_KEY=
MINIMAX_API_HOST=https://api.minimax.io

# Next.js / Auth (Phase 2)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# App
NODE_ENV=development
LOG_LEVEL=info
